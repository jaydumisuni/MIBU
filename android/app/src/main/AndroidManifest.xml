<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:theme="@style/AppTheme"
        android:label="MIBU"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:usesCleartextTraffic="false">

        <activity android:name=".CommunityCheckActivity" android:exported="false" android:screenOrientation="sensorPortrait" />
        <activity android:name=".UnlockMethodsActivity" android:exported="false" android:screenOrientation="sensorPortrait" />
        <activity android:name=".VerificationResultActivity" android:exported="false" android:screenOrientation="sensorPortrait" />
        <activity android:name=".GuideActivity" android:exported="false" android:screenOrientation="sensorPortrait" />
        <activity android:name=".InstructionsActivity" android:exported="false" android:screenOrientation="sensorPortrait" />
        <activity android:name=".LogsActivity" android:exported="false" android:screenOrientation="sensorPortrait" />
        <activity
            android:name=".TokenImportActivity"
            android:exported="true"
            android:permission="android.permission.DUMP"
            android:screenOrientation="sensorPortrait"
            android:excludeFromRecents="true" />
        <activity
            android:name=".StartWaitingActivity"
            android:exported="true"
            android:permission="android.permission.DUMP"
            android:screenOrientation="sensorPortrait"
            android:excludeFromRecents="true" />
        <activity
            android:name=".StatusActivity"
            android:exported="true"
            android:permission="android.permission.DUMP"
            android:screenOrientation="sensorPortrait"
            android:excludeFromRecents="true"
            android:noHistory="true" />
        <activity android:name=".MainActivity" android:exported="true" android:screenOrientation="sensorPortrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".MibuForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
